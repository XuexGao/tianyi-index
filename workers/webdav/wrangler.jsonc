{
  "$schema": "https://json.schemastore.org/wrangler.json",
  "name": "tianyi-webdav",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-21",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "dav.example.com/*",
      "zone_name": "example.com"
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
