# ============================================================
# 天翼云配置
# ============================================================

# 天翼云账号（必须）
TIANYI_USERNAME=your_189_phone_or_email
TIANYI_PASSWORD=your_189_password

# 默认浏览的文件夹 ID（可选，默认为 -11 即根目录）
DEFAULT_FOLDER_ID=-11

# 天翼云挂载路径（可选，默认 / 即网站根目录）
# 设为 /Tianyi 则天翼云文件出现在 /Tianyi 路径下
NEXT_PUBLIC_TIANYI_MOUNT_PATH=/

# 天翼云私密目录（可选，多个用逗号分隔，需在对应目录下放 .password 文件）
NEXT_PUBLIC_PROTECTED_ROUTES=/其他文件/文件传输

# ============================================================
# OneDrive 配置（可选，不配置则只使用天翼云）
# ============================================================

# OneDrive 挂载路径（可选，默认 /OneDrive）
# 天翼云根目录列表会自动出现一个 OneDrive 文件夹入口
NEXT_PUBLIC_ONEDRIVE_MOUNT_PATH=/OneDrive

# OneDrive 远端根目录（可选，默认 / 即 OneDrive 根目录）
# 设为 /Photos/Blog 则只挂载该子目录
BASE_DIRECTORY=/

# Microsoft OAuth 客户端 ID（启用 OneDrive 时必须）
# 在 Azure Portal → App registrations 注册应用获取
CLIENT_ID=

# Microsoft OAuth 客户端密钥（启用 OneDrive 时必须）
# 注意：需要先用 onedrive-index-oauth 三步流程加密后填入
# 加密工具使用 AES 密钥 'onedrive-vercel-index'（见 oAuthHandler.ts）
CLIENT_SECRET=

# Microsoft 账户 UPN（启用 OneDrive 时必须，用于 OAuth 身份校验）
USER_PRINCIPAL_NAME=

# OneDrive 私密目录（可选，多个用逗号分隔，路径相对于 BASE_DIRECTORY）
NEXT_PUBLIC_PROTECTED_ROUTES_OD=

# ============================================================
# 通用配置
# ============================================================

# Redis（Upstash）连接字符串（必须，用于存储天翼云会话 Cookie 和 OneDrive OAuth Token）
# 必须使用 rediss:// （双 s，TLS）格式，例如：
# rediss://default:<密码>@<区域>.upstash.io:6379
REDIS_URL=rediss://default:xxxxx@xxxx.upstash.io:6379

# Redis KV 前缀（可选，多项目共用时区分）
KV_PREFIX=

# 网站标题（可选）
NEXT_PUBLIC_SITE_TITLE=我的天翼云

# 联系邮箱（可选）
NEXT_PUBLIC_EMAIL=

# Umami 统计（可选，三个变量需同时配置）
NEXT_PUBLIC_UMAMI_BASE_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SHARE_ID=
